# .htaccess for Hostinger Node.js Proxy
RewriteEngine On
RewriteBase /

# 1. If it's a real file (like index.html or assets), serve it directly
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# 2. Proxy everything else to Node.js (API, SPA)
# We use [P] for proxy, [L] for last rule, [QSA] to preserve query strings
RewriteRule ^(.*)$ http://localhost:3000/$1 [P,L,QSA]

# 3. Security: Prevent access to .env and other sensitive files
<FilesMatch "^\.">
    Order allow,deny
    Deny from all
</FilesMatch>
