{
  "entities": {
    "Game": {
      "title": "Game",
      "description": "Represents a quiz game session.",
      "type": "object",
      "properties": {
        "pin": { "type": "string", "description": "Unique 6-digit game PIN." },
        "status": { 
          "type": "string", 
          "enum": ["lobby", "playing", "results", "ended"],
          "description": "Current status of the game."
        },
        "hostId": { "type": "string", "description": "UID of the game host." },
        "currentQuestionIndex": { "type": "number", "description": "Index of the current question." },
        "totalQuestions": { "type": "number", "description": "Total number of questions in the quiz." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the game was created." },
        "questions": {
          "type": "array",
          "description": "List of quiz questions."
        },
        "branding": {
          "type": "object",
          "description": "Custom branding settings for the game session."
        }
      },
      "required": ["pin", "status", "hostId", "currentQuestionIndex", "totalQuestions", "createdAt", "questions"]
    },
    "Player": {
      "title": "Player",
      "description": "Represents a player in a specific game.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "UID of the player." },
        "name": { "type": "string", "description": "Nickname of the player." },
        "score": { "type": "number", "description": "Current score of the player." },
        "lastAnswer": { "type": "number", "description": "Index of the last submitted answer." },
        "isCorrect": { "type": "boolean", "description": "Whether the last answer was correct." },
        "joinedAt": { "type": "string", "format": "date-time", "description": "When the player joined the game." }
      },
      "required": ["id", "name", "score", "joinedAt"]
    },
    "Quiz": {
      "title": "Quiz",
      "description": "A saved quiz template.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique ID of the quiz." },
        "title": { "type": "string", "description": "Title of the quiz." },
        "description": { "type": "string", "description": "Optional description." },
        "hostId": { "type": "string", "description": "UID of the creator." },
        "questions": { "type": "array", "description": "List of questions." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the quiz was created." }
      },
      "required": ["id", "title", "hostId", "questions", "createdAt"]
    },
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile and subscription data.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "User ID." },
        "isPremium": { "type": "boolean", "description": "Whether the user has a premium subscription." },
        "premiumSource": { "type": "string", "enum": ["purchase", "admin"], "description": "Source of the premium subscription." },
        "branding": {
          "type": "object",
          "properties": {
            "logoUrl": { "type": "string" },
            "primaryColor": { "type": "string" },
            "secondaryColor": { "type": "string" }
          }
        },
        "tourStatus": {
          "type": "object",
          "properties": {
            "hasSeenOnboarding": { "type": "boolean" },
            "seenFeatures": { "type": "array", "items": { "type": "string" } }
          }
        },
        "updatedAt": { "type": "string", "format": "date-time", "description": "Last update timestamp." }
      },
      "required": ["uid", "isPremium"]
    },
    "GameSummary": {
      "title": "GameSummary",
      "description": "Historical summary of a completed game for analytics.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "quizId": { "type": "string" },
        "quizTitle": { "type": "string" },
        "hostId": { "type": "string" },
        "playerCount": { "type": "number" },
        "avgScore": { "type": "number" },
        "questionStats": { "type": "array" },
        "leaderboard": { "type": "array" },
        "completedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "quizId", "hostId", "playerCount", "completedAt"]
    }
  },
  "firestore": {
    "/games/{pin}": {
      "schema": "Game",
      "description": "Main game document."
    },
    "/games/{pin}/players/{playerId}": {
      "schema": "Player",
      "description": "Sub-collection of players in a game."
    },
    "/quizzes/{quizId}": {
      "schema": "Quiz",
      "description": "Collection of saved quizzes."
    },
    "/users/{uid}": {
      "schema": "UserProfile",
      "description": "User profile data."
    },
    "/gameSummaries/{summaryId}": {
      "schema": "GameSummary",
      "description": "Historical game data for analytics."
    }
  }
}
