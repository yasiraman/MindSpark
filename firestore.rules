// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: games
// Document ID: {pin} (6-digit string)
// Fields:
//   - pin: string (required)
//   - status: string (required, ['lobby', 'playing', 'results', 'ended'])
//   - hostId: string (required, UID of creator)
//   - currentQuestionIndex: number (required)
//   - totalQuestions: number (required)
//   - createdAt: timestamp (required)
//   - questions: list (required)
//
// Collection: games/{pin}/players
// Document ID: {playerId} (UID)
// Fields:
//   - id: string (required, matches UID)
//   - name: string (required, 1-20 chars)
//   - score: number (required, >= 0)
//   - lastAnswer: number (optional)
//   - isCorrect: bool (optional)
//   - joinedAt: timestamp (required)
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isHost(pin) {
      return isAuthenticated() && request.auth.uid == get(/databases/$(database)/documents/games/$(pin)).data.hostId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (request.auth.token.email == "yasiraman20@gmail.com" && request.auth.token.email_verified == true);
    }

    function isValidGame(data) {
      return data.pin is string && data.pin.size() == 6 &&
             data.status in ['lobby', 'playing', 'results', 'ended'] &&
             data.hostId is string &&
             data.currentQuestionIndex is number &&
             data.totalQuestions is number &&
             data.questions is list &&
             (data.createdAt is timestamp || data.createdAt == request.time) &&
             (!('branding' in data) || data.branding == null || data.branding is map);
    }

    function isValidPlayer(data) {
      return data.id is string &&
             data.name is string && data.name.size() >= 1 && data.name.size() <= 20 &&
             data.score is number && data.score >= 0 &&
             (data.joinedAt is timestamp || data.joinedAt == request.time) &&
             (!('lastAnswer' in data) || data.lastAnswer is number) &&
             (!('isCorrect' in data) || data.isCorrect is bool);
    }

    function isValidQuiz(data) {
      return data.id is string &&
             data.title is string && data.title.size() >= 1 && data.title.size() <= 100 &&
             data.hostId is string &&
             data.questions is list &&
             (data.createdAt is timestamp || data.createdAt == request.time);
    }

    function isValidUser(data) {
      return data.uid is string &&
             data.isPremium is bool &&
             (!('branding' in data) || data.branding is map) &&
             (!('tourStatus' in data) || data.tourStatus is map) &&
             (!('updatedAt' in data) || data.updatedAt is timestamp || data.updatedAt == request.time);
    }

    function isValidGameSummary(data) {
      return data.id is string &&
             data.quizId is string &&
             data.quizTitle is string &&
             data.hostId is string &&
             data.playerCount is number &&
             data.avgScore is number &&
             data.questionStats is list &&
             data.leaderboard is list &&
             (data.completedAt is timestamp || data.completedAt == request.time);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{uid} {
      allow read: if isOwner(uid);
      allow create: if isOwner(uid) && isValidUser(request.resource.data);
      allow update: if isOwner(uid) && isValidUser(request.resource.data) && 
                      (request.resource.data.isPremium == resource.data.isPremium || isAdmin());
    }

    match /gameSummaries/{summaryId} {
      // Users can only see their own game summaries
      allow read: if isAuthenticated() && resource.data.hostId == request.auth.uid;
      // Only the host can create a summary for their game
      allow create: if isAuthenticated() && 
                      isValidGameSummary(request.resource.data) &&
                      request.resource.data.hostId == request.auth.uid;
    }

    match /quizzes/{quizId} {
      // Users can only see their own quizzes
      allow read: if isOwner(resource.data.hostId);
      
      // Users can create quizzes where they are the host
      allow create: if isAuthenticated() && 
                      isValidQuiz(request.resource.data) && 
                      request.resource.data.hostId == request.auth.uid;
      
      // Users can update their own quizzes
      allow update: if isOwner(resource.data.hostId) && 
                      isValidQuiz(request.resource.data) &&
                      request.resource.data.hostId == request.auth.uid;

      // Users can delete their own quizzes
      allow delete: if isOwner(resource.data.hostId);
    }

    match /games/{pin} {
      // Anyone authenticated can read a game (to join or watch)
      allow read: if isAuthenticated();
      
      // Only authenticated users can create a game, and they must be the host
      allow create: if isAuthenticated() && 
                      isValidGame(request.resource.data) && 
                      request.resource.data.hostId == request.auth.uid;
      
      // Only the host can update the game state
      allow update: if isHost(pin) && 
                      isValidGame(request.resource.data) &&
                      request.resource.data.hostId == resource.data.hostId; // hostId is immutable

      match /players/{playerId} {
        // Host and the player themselves can read player data
        allow read: if isAuthenticated() && (isHost(pin) || isOwner(playerId));
        
        // Players can join if they are authenticated and the game is in lobby
        allow create: if isOwner(playerId) && 
                        isValidPlayer(request.resource.data) &&
                        get(/databases/$(database)/documents/games/$(pin)).data.status == 'lobby';
        
        // Players can update their own answers, Host can update scores
        allow update: if isAuthenticated() && 
                        isValidPlayer(request.resource.data) &&
                        (
                          // Player updating their own answer
                          (isOwner(playerId) && 
                           get(/databases/$(database)/documents/games/$(pin)).data.status == 'playing' &&
                           request.resource.data.diff(resource.data).affectedKeys().hasOnly(['lastAnswer', 'isCorrect', 'score'])) ||
                          // Host updating scores/results
                          isHost(pin)
                        );
      }
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
